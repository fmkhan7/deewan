---
layout: layouts/base.njk
eleventyExcludeFromCollections: true
pagination:
  data: collections.nazms
  size: 1
  alias: nazm
permalink: nazms/{{ nazm.data.slug }}/
---

<article class="nazm">
  <header class="poetry-header">
    <h1>{{ nazm.data.title }}</h1>
    {% if nazm.data.meter %}
    <p class="meter">بحر: {{ nazm.data.meter }}</p>
    {% endif %}
  </header>

  <div class="verses">
  {% for verse in nazm.data.verses %}
    <p class="verse">{{ verse }}</p>
  {% endfor %}
  </div>

  <footer class="poetry-footer">
    <a href="/nazms/" class="back-link">← نظیمیں</a>
  </footer>
</article>
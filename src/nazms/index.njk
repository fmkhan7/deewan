---
layout: layouts/base.njk
title: نظیمیں - Nazms
---

<div class="poetry-index">
  <header class="page-header">
    <h1>نظمیں</h1>
    <p class="count">{{ nazms | length }} نظیمیں</p>
  </header>

  <ul class="poetry-list">
  {% for nazm in nazms %}
    <li class="poetry-item">
      <a href="{{ site.baseurl }}/nazms/{{ nazm.data.slug }}/">
        <span class="title">{{ nazm.data.title }}</span>
      </a>
      {% if nazm.data.meter %}
      <span class="meter">{{ nazm.data.meter }}</span>
      {% endif %}
    </li>
  {% endfor %}
  </ul>

  {% if nazms.length == 0 %}
  <p class="empty-message">نظمیں جلد آئیں گی۔</p>
  {% endif %}
</div>
---
layout: layouts/base.njk
permalink: /
---

<div class="home-page">
  <section class="hero">
    <h2>خوش آمدید</h2>
    <p class="tagline">{{ collection.description }}</p>
  </section>

  <section class="collections">
    {% for coll in poetry_collections %}
    <div class="collection-card">
      <h3><a href="{{ site.baseurl }}/{{ coll.slug }}/">{{ coll.title }}</a></h3>
      <p>{{ coll.author }}</p>
    </div>
    {% endfor %}
  </section>
</div>